From cf1964d77922e7e69c62e5d350a98c61434db48f Mon Sep 17 00:00:00 2001
From: Daniel Linjama <daniel@dev.linjama.com>
Date: Fri, 6 Jan 2023 12:03:49 +0200
Subject: [PATCH] rpm: add RPM spec for akmod-zfs

Akmods RPM package for CoreOS and Silverblue support

Signed-off-by: Daniel Linjama <daniel@dev.linjama.com>
---
 config/rpm.am                 |  22 ++++---
 config/zfs-build.m4           |   6 ++
 configure.ac                  |   1 +
 rpm/Makefile.am               |   1 +
 rpm/generic/zfs-akmod.spec.in | 112 ++++++++++++++++++++++++++++++++++
 5 files changed, 135 insertions(+), 7 deletions(-)
 create mode 100644 rpm/generic/zfs-akmod.spec.in

diff --git a/config/rpm.am b/config/rpm.am
index 4ccf549b3..b8b01a004 100644
--- a/config/rpm.am
+++ b/config/rpm.am
@@ -7,16 +7,20 @@
 # Build targets for RPM packages.
 ###############################################################################
 
-PHONY += srpm srpms srpm-kmod srpm-dkms srpm-utils
-PHONY += rpm rpms rpm-kmod rpm-dkms rpm-utils rpm-utils-initramfs
+PHONY += srpm srpms srpm-kmod srpm-akmod srpm-dkms srpm-utils
+PHONY += rpm rpms rpm-kmod rpm-akmod rpm-dkms rpm-utils rpm-utils-initramfs
 PHONY += srpm-common rpm-common rpm-local
 
-srpm-kmod srpm-dkms srpm-utils: dist
+srpm-kmod srpm-akmod srpm-dkms srpm-utils: dist
 
 srpm-kmod:
 	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}-kmod" \
 		def='${SRPM_DEFINE_COMMON} ${SRPM_DEFINE_KMOD}' srpm-common
 
+srpm-akmod:
+	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}-akmod" \
+		def='${SRPM_DEFINE_COMMON} ${SRPM_DEFINE_AKMOD}' srpm-common
+
 srpm-dkms:
 	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}-dkms" \
 		def='${SRPM_DEFINE_COMMON} ${SRPM_DEFINE_DKMS}' srpm-common
@@ -25,13 +29,17 @@ srpm-utils:
 	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}" \
 		def='${SRPM_DEFINE_COMMON} ${SRPM_DEFINE_UTIL}' srpm-common
 
-srpm: srpm-kmod srpm-dkms srpm-utils
-srpms: srpm-kmod srpm-dkms srpm-utils
+srpm: srpm-kmod srpm-akmod srpm-dkms srpm-utils
+srpms: srpm-kmod srpm-akmod srpm-dkms srpm-utils
 
 rpm-kmod: srpm-kmod
 	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}-kmod" \
 		def='${RPM_DEFINE_COMMON} ${RPM_DEFINE_KMOD}' rpm-common
 
+rpm-akmod: srpm-akmod
+	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}-akmod" \
+		def='${RPM_DEFINE_COMMON} ${RPM_DEFINE_AKMOD}' rpm-common
+
 rpm-dkms: srpm-dkms
 	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}-dkms" \
 		def='${RPM_DEFINE_COMMON} ${RPM_DEFINE_DKMS}' rpm-common
@@ -52,8 +60,8 @@ rpm-utils-initramfs: srpm-utils
 	$(MAKE) $(AM_MAKEFLAGS) pkg="${PACKAGE}" \
 		def='${RPM_DEFINE_COMMON} ${RPM_DEFINE_UTIL} ${RPM_DEFINE_INITRAMFS}' rpm-common
 
-rpm: rpm-kmod rpm-dkms rpm-utils
-rpms: rpm-kmod rpm-dkms rpm-utils
+rpm: rpm-kmod rpm-akmod rpm-dkms rpm-utils
+rpms: rpm-kmod rpm-akmod rpm-dkms rpm-utils
 
 rpm-local:
 	@(if test "${HAVE_RPMBUILD}" = "no"; then \
diff --git a/config/zfs-build.m4 b/config/zfs-build.m4
index 9d829a4e6..4f31dce47 100644
--- a/config/zfs-build.m4
+++ b/config/zfs-build.m4
@@ -469,11 +469,15 @@ AC_DEFUN([ZFS_AC_RPM], [
 		RPM_DEFINE_KMOD=${RPM_DEFINE_KMOD}' --define "kernel_arch KERNEL_ARCH=$(KERNEL_ARCH)"'
 	])
 
+	RPM_DEFINE_AKMOD='--define "_wrong_version_format_terminate_build 0"'
+	RPM_DEFINE_AKMOD=${RPM_DEFINE_AKMOD}' --define "akmod 1"'
+
 	RPM_DEFINE_DKMS=''
 
 	SRPM_DEFINE_COMMON='--define "build_src_rpm 1"'
 	SRPM_DEFINE_UTIL=
 	SRPM_DEFINE_KMOD=
+	SRPM_DEFINE_AKMOD=
 	SRPM_DEFINE_DKMS=
 
 	RPM_SPEC_DIR="rpm/generic"
@@ -496,10 +500,12 @@ AC_DEFUN([ZFS_AC_RPM], [
 	AC_SUBST(RPM_SPEC_DIR)
 	AC_SUBST(RPM_DEFINE_UTIL)
 	AC_SUBST(RPM_DEFINE_KMOD)
+	AC_SUBST(RPM_DEFINE_AKMOD)
 	AC_SUBST(RPM_DEFINE_DKMS)
 	AC_SUBST(RPM_DEFINE_COMMON)
 	AC_SUBST(SRPM_DEFINE_UTIL)
 	AC_SUBST(SRPM_DEFINE_KMOD)
+	AC_SUBST(SRPM_DEFINE_AKMOD)
 	AC_SUBST(SRPM_DEFINE_DKMS)
 	AC_SUBST(SRPM_DEFINE_COMMON)
 ])
diff --git a/configure.ac b/configure.ac
